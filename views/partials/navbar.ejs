<nav class="bg-white shadow-md" x-data="{ open: false }">
    <div class="container mx-auto px-4">
        <div class="flex justify-between items-center h-16">
            <a href="/" class="text-xl font-bold text-blue-600">CommunityPulse</a>
            
            <div class="hidden md:flex space-x-4">
                <% if (locals.user) { %>
                    <a href="/dashboard" class="text-gray-600 hover:text-blue-600">Dashboard</a>
                    <a href="/feedback" class="text-gray-600 hover:text-blue-600">Submit</a>
                    <% if (user.role === 'admin') { %>
                        <a href="/admin" class="text-gray-600 hover:text-blue-600">Admin</a>
                    <% } %>
                    <a href="/logout" class="text-red-600 hover:text-red-800">Logout</a>
                <% } else { %>
                    <a href="/login" class="text-gray-600 hover:text-blue-600">Login</a>
                    <a href="/register" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Register</a>
                <% } %>
            </div>

            <!-- Mobile Menu Button -->
            <button @click="open = !open" class="md:hidden text-gray-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
            </button>
        </div>
    </div>
    <!-- Mobile Menu -->
    <div x-show="open" class="md:hidden bg-white border-t">
        <a href="/dashboard" class="block px-4 py-2 text-gray-600">Dashboard</a>
        <a href="/feedback" class="block px-4 py-2 text-gray-600">Submit</a>
        <a href="/logout" class="block px-4 py-2 text-red-600">Logout</a>
    </div>
</nav>