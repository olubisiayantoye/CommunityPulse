<!-- views/pages/dashboard.ejs -->
<div class="space-y-8" x-data="dashboard()">
    
    <!-- Welcome Banner -->
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 rounded-2xl p-6 text-white shadow-lg">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between">
            <div>
                <h2 class="text-2xl font-bold">Welcome, <%= typeof user !== 'undefined' ? user.username : 'Member' %>!</h2>
                <p class="mt-1 opacity-90">Share your thoughts and help improve our community.</p>
            </div>
            <a href="/feedback" class="mt-4 md:mt-0 inline-flex items-center px-4 py-2 bg-white text-blue-600 rounded-lg font-medium hover:bg-blue-50 transition">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                New Feedback
            </a>
        </div>
    </div>

    <!-- Filters Bar -->
    <div class="bg-white rounded-xl shadow p-4">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div class="flex flex-wrap items-center gap-3">
                <!-- Category Filter -->
                <select x-model="filters.category" @change="applyFilters()"
                        class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500">
                    <option value="">All Categories</option>
                    <% if (typeof categories !== 'undefined') { %>
                        <% categories.forEach(cat => { %>
                            <option value="<%= cat.id %>"><%= cat.name %></option>
                        <% }) %>
                    <% } %>
                </select>
                
                <!-- Sentiment Filter -->
                <select x-model="filters.sentiment" @change="applyFilters()"
                        class="px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500">
                    <option value="">All Sentiments</option>
                    <option value="Positive">😊 Positive</option>
                    <option value="Neutral">😐 Neutral</option>
                    <option value="Negative">😔 Negative</option>
                </select>
                
                <!-- Reset Filters -->
                <button @click="resetFilters()" class="text-sm text-gray-500 hover:text-gray-700 underline">
                    Reset
                </button>
            </div>
            
            <!-- Results Count -->
            <p class="text-sm text-gray-500">
                Showing <span x-text="filteredCount"></span> of <%= typeof feedbacks !== 'undefined' ? feedbacks.length : 0 %> items
            </p>
        </div>
    </div>

    <!-- Feedback List -->
    <div class="space-y-4" id="feedback-list">
        <% if (typeof feedbacks !== 'undefined' && feedbacks.length > 0) { %>
            <% feedbacks.forEach(fb => { %>
                <article class="bg-white rounded-xl shadow p-5 border-l-4 
                    <%= fb.sentiment_label === 'Positive' ? 'border-green-500' : 
                        fb.sentiment_label === 'Negative' ? 'border-red-500' : 'border-yellow-500' %>
                    animate-fade-in"
                    x-data="{ expanded: false }">
                    
                    <div class="flex justify-between items-start">
                        <div class="flex-1">
                            <!-- Category & Sentiment Badges -->
                            <div class="flex flex-wrap items-center gap-2 mb-2">
                                <% if (fb.category_name) { %>
                                    <span class="text-xs font-medium px-2 py-1 rounded" 
                                          style="background: <%= fb.category_color %>20; color: <%= fb.category_color %>">
                                        <%= fb.category_name %>
                                    </span>
                                <% } %>
                                <span class="text-xs font-medium px-2 py-1 rounded
                                    <%= fb.sentiment_label === 'Positive' ? 'bg-green-100 text-green-800' : 
                                        fb.sentiment_label === 'Negative' ? 'bg-red-100 text-red-800' : 
                                        'bg-yellow-100 text-yellow-800' %>">
                                    <%= fb.sentiment_label %>
                                </span>
                                <% if (fb.is_anonymous) { %>
                                    <span class="text-xs text-gray-400">• Anonymous</span>
                                <% } %>
                            </div>
                            
                            <!-- Message (expandable if long) -->
                            <p class="text-gray-800" 
                               :class="fb.message.length > 200 && !expanded ? 'line-clamp-3' : ''"
                               x-text="fb.message"></p>
                            
                            <% if (fb.message && fb.message.length > 200) { %>
                                <button @click="expanded = !expanded" class="text-sm text-blue-600 hover:underline mt-1">
                                    <span x-text="expanded ? 'Show less' : 'Show more'"></span>
                                </button>
                            <% } %>
                            
                            <!-- Metadata -->
                            <div class="flex items-center gap-4 mt-3 text-xs text-gray-500">
                                <time datetime="<%= new Date(fb.created_at).toISOString() %>">
                                    <%= new Date(fb.created_at).toLocaleDateString() %>
                                </time>
                                <% if (fb.status && fb.status !== 'pending') { %>
                                    <span class="px-2 py-0.5 rounded bg-gray-100 text-gray-600">
                                        <%= fb.status.replace('_', ' ') %>
                                    </span>
                                <% } %>
                            </div>
                        </div>
                        
                        <!-- Vote Button (for non-admin, non-owner feedback) -->
                        <% if (typeof user !== 'undefined' && user.role !== 'admin' && fb.is_anonymous) { %>
                            <button hx-post="/feedback/<%= fb.id %>/vote"
                                    hx-vals='{"vote_type": "up"}'
                                    hx-target="this .vote-count"
                                    hx-swap="innerHTML"
                                    class="ml-4 flex flex-col items-center text-gray-400 hover:text-blue-600 transition"
                                    title="Upvote this feedback">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path>
                                </svg>
                                <span class="vote-count text-xs font-medium"><%= fb.upvotes || 0 %></span>
                            </button>
                        <% } %>
                    </div>
                    
                </article>
            <% }) %>
        <% } else { %>
            <!-- Empty State -->
            <div class="bg-white rounded-xl shadow p-12 text-center">
                <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                </svg>
                <h3 class="text-lg font-medium text-gray-800 mb-2">No feedback yet</h3>
                <p class="text-gray-600 mb-4">Be the first to share your thoughts with the community!</p>
                <a href="/feedback" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">
                    Submit Feedback
                </a>
            </div>
        <% } %>
    </div>

    <!-- Load More (if pagination implemented) -->
    <% if (typeof pagination !== 'undefined' && pagination.hasMore) { %>
        <div class="text-center">
            <button hx-get="/feedback/dashboard?page=<%= pagination.next %>"
                    hx-target="#feedback-list"
                    hx-swap="beforeend"
                    class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition">
                Load More
            </button>
        </div>
    <% } %>

</div>

<script>
function dashboard() {
    return {
        filters: {
            category: '<%= typeof filters !== 'undefined' && filters.category ? filters.category : '' %>',
            sentiment: '<%= typeof filters !== 'undefined' && filters.sentiment ? filters.sentiment : '' %>'
        },
        allFeedback: <%= typeof feedbacks !== 'undefined' ? JSON.stringify(feedbacks) : '[]' %>,
        
        get filteredCount() {
            // Simple client-side filtering (for demo; use server-side for production)
            return this.allFeedback.filter(fb => {
                if (this.filters.category && fb.category_id != this.filters.category) return false;
                if (this.filters.sentiment && fb.sentiment_label !== this.filters.sentiment) return false;
                return true;
            }).length;
        },
        
        applyFilters() {
            // In production, this would trigger an HTMX request to server
            // For now, just log for demonstration
            console.log('Filters applied:', this.filters);
            // window.location.search = new URLSearchParams(this.filters).toString();
        },
        
        resetFilters() {
            this.filters.category = '';
            this.filters.sentiment = '';
            this.applyFilters();
        }
    }
}
</script>