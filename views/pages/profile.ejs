<!-- views/pages/profile.ejs -->
<div class="max-w-3xl mx-auto" x-data="profileForm()">
    
    <!-- Page Header -->
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-800">My Profile</h1>
        <p class="text-gray-600 mt-1">Manage your account settings and preferences</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- Profile Card (Left Sidebar) -->
        <div class="md:col-span-1">
            <div class="bg-white rounded-xl shadow p-6 text-center">
                <!-- Avatar -->
                <div class="w-24 h-24 mx-auto bg-gradient-to-br from-blue-500 to-blue-700 rounded-full flex items-center justify-center text-white text-3xl font-bold mb-4">
                    <%= typeof user !== 'undefined' && user.username ? user.username.charAt(0).toUpperCase() : 'U' %>
                </div>
                
                <h2 class="text-xl font-semibold text-gray-800"><%= typeof user !== 'undefined' && user.username ? user.username : 'User' %></h2>
                <p class="text-sm text-gray-500 capitalize mt-1"><%= typeof user !== 'undefined' && user.role ? user.role : 'member' %></p>
                
                <!-- Account Stats -->
                <div class="mt-6 pt-6 border-t border-gray-200">
                    <div class="grid grid-cols-2 gap-4 text-center">
                        <div>
                            <p class="text-2xl font-bold text-gray-800"><%= typeof stats !== 'undefined' ? stats.feedback_count || 0 : 0 %></p>
                            <p class="text-xs text-gray-500">Feedback</p>
                        </div>
                        <div>
                            <p class="text-2xl font-bold text-gray-800"><%= typeof stats !== 'undefined' ? stats.days_member || 0 : 0 %></p>
                            <p class="text-xs text-gray-500">Days</p>
                        </div>
                    </div>
                </div>
                
                <!-- Member Since -->
                <p class="text-xs text-gray-400 mt-4">
                    Member since <%= typeof user !== 'undefined' && user.created_at ? new Date(user.created_at).toLocaleDateString() : 'N/A' %>
                </p>
            </div>
        </div>

        <!-- Profile Forms (Right Content) -->
        <div class="md:col-span-2 space-y-6">
            
            <!-- Update Email Form -->
            <div class="bg-white rounded-xl shadow p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Email Settings</h3>
                
                <form hx-put="/profile/email" 
                      hx-target="#email-response" 
                      hx-swap="innerHTML"
                      hx-indicator="#email-btn"
                      @submit.prevent="submitForm('email')">
                    
                    <div class="mb-4">
                        <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                            Email Address
                        </label>
                        <input type="email" 
                               id="email" 
                               name="email" 
                               value="<%= typeof user !== 'undefined' && user.email ? user.email : '' %>"
                               placeholder="your@email.com"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                               :class="{ 'border-red-500': errors.email }">
                        <p x-show="errors.email" class="text-xs text-red-500 mt-1" x-text="errors.email"></p>
                    </div>
                    
                    <div id="email-response"></div>
                    
                    <button type="submit" 
                            id="email-btn"
                            class="inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition disabled:opacity-50">
                        <span x-show="!isSubmitting.email">Update Email</span>
                        <span x-show="isSubmitting.email" class="flex items-center">
                            <svg class="animate-spin h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            Saving...
                        </span>
                    </button>
                </form>
            </div>

            <!-- Change Password Form -->
            <div class="bg-white rounded-xl shadow p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Change Password</h3>
                
                <form hx-put="/profile/password" 
                      hx-target="#password-response" 
                      hx-swap="innerHTML"
                      hx-indicator="#password-btn"
                      @submit.prevent="submitForm('password')">
                    
                    <div class="space-y-4">
                        <div>
                            <label for="current_password" class="block text-sm font-medium text-gray-700 mb-2">
                                Current Password
                            </label>
                            <input type="password" 
                                   id="current_password" 
                                   name="current_password" 
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                                   :class="{ 'border-red-500': errors.current_password }"
                                   required>
                            <p x-show="errors.current_password" class="text-xs text-red-500 mt-1" x-text="errors.current_password"></p>
                        </div>
                        
                        <div>
                            <label for="new_password" class="block text-sm font-medium text-gray-700 mb-2">
                                New Password
                            </label>
                            <input type="password" 
                                   id="new_password" 
                                   name="new_password" 
                                   x-model="newPassword"
                                   @input="checkPasswordStrength()"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                                   :class="{ 'border-red-500': errors.new_password, 'border-green-500': passwordStrength === 'strong' }"
                                   minlength="8"
                                   required>
                            
                            <!-- Password Strength -->
                            <div class="mt-2" x-show="newPassword">
                                <div class="flex space-x-1">
                                    <div class="h-1 flex-1 rounded" :class="passwordStrengthBar(0)"></div>
                                    <div class="h-1 flex-1 rounded" :class="passwordStrengthBar(1)"></div>
                                    <div class="h-1 flex-1 rounded" :class="passwordStrengthBar(2)"></div>
                                    <div class="h-1 flex-1 rounded" :class="passwordStrengthBar(3)"></div>
                                </div>
                                <p class="text-xs mt-1" 
                                   :class="{ 
                                       'text-red-500': passwordStrength === 'weak', 
                                       'text-yellow-500': passwordStrength === 'medium', 
                                       'text-green-500': passwordStrength === 'strong' 
                                   }" 
                                   x-text="passwordStrengthText()">
                                </p>
                            </div>
                            <p x-show="errors.new_password" class="text-xs text-red-500 mt-1" x-text="errors.new_password"></p>
                        </div>
                        
                        <div>
                            <label for="confirm_password" class="block text-sm font-medium text-gray-700 mb-2">
                                Confirm New Password
                            </label>
                            <input type="password" 
                                   id="confirm_password" 
                                   name="confirm_password" 
                                   x-model="confirmPassword"
                                   @input="validatePasswordMatch()"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                                   :class="{ 'border-red-500': !passwordMatch && confirmPassword, 'border-green-500': passwordMatch && confirmPassword }"
                                   required>
                            <p x-show="!passwordMatch && confirmPassword" class="text-xs text-red-500 mt-1">Passwords do not match</p>
                            <p x-show="passwordMatch && confirmPassword" class="text-xs text-green-500 mt-1">Passwords match</p>
                        </div>
                    </div>
                    
                    <div id="password-response" class="mt-4"></div>
                    
                    <button type="submit" 
                            id="password-btn"
                            class="inline-flex items-center px-4 py-2 bg-blue-600 text-white font-medium rounded-lg hover:bg-blue-700 transition disabled:opacity-50 mt-4"
                            :disabled="!canChangePassword">
                        <span x-show="!isSubmitting.password">Change Password</span>
                        <span x-show="isSubmitting.password" class="flex items-center">
                            <svg class="animate-spin h-4 w-4 mr-2" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            Updating...
                        </span>
                    </button>
                </form>
            </div>

            <!-- Account Actions -->
            <div class="bg-white rounded-xl shadow p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Account Actions</h3>
                
                <div class="space-y-3">
                    <!-- Notification Preferences -->
                    <div class="flex items-center justify-between py-3 border-b border-gray-100">
                        <div>
                            <p class="text-sm font-medium text-gray-800">Email Notifications</p>
                            <p class="text-xs text-gray-500">Receive updates about your feedback</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="notifications" x-model="notifications" class="sr-only peer">
                            <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-blue-600"></div>
                        </label>
                    </div>
                    
                    <!-- Delete Account (Danger Zone) -->
                    <div class="pt-4">
                        <h4 class="text-sm font-semibold text-red-600 mb-2">Danger Zone</h4>
                        <p class="text-xs text-gray-500 mb-3">Once you delete your account, there is no going back. Please be certain.</p>
                        <button @click="showDeleteModal = true" 
                                class="inline-flex items-center px-4 py-2 bg-red-600 text-white text-sm font-medium rounded-lg hover:bg-red-700 transition">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                            Delete Account
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- Delete Account Modal -->
    <div x-show="showDeleteModal" 
         x-cloak
         class="fixed inset-0 z-50 overflow-y-auto" 
         aria-labelledby="modal-title" 
         role="dialog" 
         aria-modal="true">
        
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <!-- Background overlay -->
            <div x-show="showDeleteModal" 
                 x-transition:enter="ease-out duration-300"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100"
                 x-transition:leave="ease-in duration-200"
                 x-transition:leave-start="opacity-100"
                 x-transition:leave-end="opacity-0"
                 class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" 
                 @click="showDeleteModal = false"
                 aria-hidden="true">
            </div>

            <!-- Modal panel -->
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            <div x-show="showDeleteModal" 
                 x-transition:enter="ease-out duration-300"
                 x-transition:enter-start="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                 x-transition:enter-end="opacity-100 translate-y-0 sm:scale-100"
                 x-transition:leave="ease-in duration-200"
                 x-transition:leave-start="opacity-100 translate-y-0 sm:scale-100"
                 x-transition:leave-end="opacity-0 translate-y-4 sm:translate-y-0 sm:scale-95"
                 class="inline-block align-bottom bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
                
                <div class="bg-white px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <div class="sm:flex sm:items-start">
                        <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100 sm:mx-0 sm:h-10 sm:w-10">
                            <svg class="h-6 w-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                            </svg>
                        </div>
                        <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
                            <h3 class="text-lg leading-6 font-medium text-gray-900" id="modal-title">Delete Account</h3>
                            <div class="mt-2">
                                <p class="text-sm text-gray-500">
                                    Are you sure you want to delete your account? All your feedback and data will be permanently removed. This action cannot be undone.
                                </p>
                            </div>
                            
                            <!-- Confirmation Input -->
                            <div class="mt-4">
                                <label for="confirm-username" class="block text-sm font-medium text-gray-700 mb-1">
                                    Type your username to confirm:
                                </label>
                                <input type="text" 
                                       id="confirm-username" 
                                       x-model="deleteConfirmUsername"
                                       class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500"
                                       placeholder="<%= typeof user !== 'undefined' && user.username ? user.username : '' %>">
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="bg-gray-50 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                    <form hx-delete="/profile/account" 
                          hx-target="body" 
                          hx-swap="outerHTML"
                          @submit.prevent="deleteAccount()">
                        <button type="submit" 
                                :disabled="deleteConfirmUsername !== '<%= typeof user !== 'undefined' && user.username ? user.username : '' %>'"
                                class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-red-600 text-base font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 sm:ml-3 sm:w-auto sm:text-sm disabled:opacity-50 disabled:cursor-not-allowed">
                            Delete Account
                        </button>
                    </form>
                    <button type="button" 
                            @click="showDeleteModal = false"
                            class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>

<script>
function profileForm() {
    return {
        newPassword: '',
        confirmPassword: '',
        passwordStrength: 'weak',
        passwordMatch: false,
        notifications: true,
        showDeleteModal: false,
        deleteConfirmUsername: '',
        isSubmitting: {
            email: false,
            password: false
        },
        errors: {},
        
        checkPasswordStrength() {
            const password = this.newPassword;
            let score = 0;
            
            if (password.length >= 8) score++;
            if (password.length >= 12) score++;
            if (/[a-z]/.test(password) && /[A-Z]/.test(password)) score++;
            if (/[0-9]/.test(password)) score++;
            if (/[^a-zA-Z0-9]/.test(password)) score++;
            
            if (score <= 2) this.passwordStrength = 'weak';
            else if (score <= 4) this.passwordStrength = 'medium';
            else this.passwordStrength = 'strong';
        },
        
        passwordStrengthBar(index) {
            const strengths = {
                weak: ['bg-red-500', '', '', ''],
                medium: ['bg-yellow-500', 'bg-yellow-500', '', ''],
                strong: ['bg-green-500', 'bg-green-500', 'bg-green-500', 'bg-green-500']
            };
            const bars = strengths[this.passwordStrength];
            return index < bars.length && bars[index] ? bars[index] : 'bg-gray-200';
        },
        
        passwordStrengthText() {
            const texts = {
                weak: 'Weak - Use at least 8 characters',
                medium: 'Medium - Add numbers or symbols',
                strong: 'Strong - Great password!'
            };
            return this.newPassword ? texts[this.passwordStrength] : '';
        },
        
        validatePasswordMatch() {
            this.passwordMatch = this.newPassword === this.confirmPassword && this.confirmPassword.length > 0;
        },
        
        get canChangePassword() {
            return this.newPassword.length >= 8 && 
                   this.passwordStrength !== 'weak' && 
                   this.passwordMatch && 
                   !this.isSubmitting.password;
        },
        
        async submitForm(type) {
            this.isSubmitting[type] = true;
            this.errors = {};
            
            // Client-side validation
            if (type === 'password') {
                if (!this.canChangePassword) {
                    this.errors.new_password = 'Password does not meet requirements';
                    this.isSubmitting.password = false;
                    return;
                }
            }
            
            // Let HTMX handle the actual submission
            const form = this.$el.querySelector(type === 'email' ? 'form[hx-put="/profile/email"]' : 'form[hx-put="/profile/password"]');
            if (form && form.checkValidity()) {
                form.dispatchEvent(new Event('submit', { bubbles: true, cancelable: true }));
            }
            
            // HTMX will handle the response and update the target div
        },
        
        async deleteAccount() {
            if (this.deleteConfirmUsername !== '<%= typeof user !== 'undefined' && user.username ? user.username : '' %>') {
                return;
            }
            // HTMX will handle the deletion and redirect
        }
    }
}
</script>