<div class="max-w-md mx-auto bg-white p-8 rounded-lg shadow-lg mt-10">
    <h2 class="text-2xl font-bold mb-6 text-center">Login</h2>
    
    <% if (messages.error) { %>
        <div class="bg-red-100 text-red-700 p-3 rounded mb-4"><%= messages.error %></div>
    <% } %>
    <% if (messages.success) { %>
        <div class="bg-green-100 text-green-700 p-3 rounded mb-4"><%= messages.success %></div>
    <% } %>

    <form hx-post="/login" hx-target="body" hx-swap="outerHTML">
        <div class="mb-4">
            <label class="block text-gray-700 text-sm font-bold mb-2">Username</label>
            <input name="username" class="w-full border rounded py-2 px-3 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
        </div>
        <div class="mb-6">
            <label class="block text-gray-700 text-sm font-bold mb-2">Password</label>
            <input name="password" type="password" class="w-full border rounded py-2 px-3 focus:outline-none focus:ring-2 focus:ring-blue-500" required>
        </div>
        <button class="w-full bg-blue-600 text-white font-bold py-2 px-4 rounded hover:bg-blue-700 transition">
            Sign In
        </button>
    </form>
    <p class="mt-4 text-center text-sm">
        <a href="/register" class="text-blue-600 hover:underline">Create an account</a>
    </p>
</div>