<!-- views/pages/register.ejs -->
<div class="min-h-[80vh] flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    
    <div class="max-w-md w-full bg-white rounded-2xl shadow-xl p-8 animate-slide-up"
         x-data="registerForm()"
         x-init="init()">

        <!-- Header -->
        <div class="text-center mb-8">
            <div class="bg-blue-600 text-white w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"></path>
                </svg>
            </div>
            <h1 class="text-3xl font-bold text-gray-800">Create Account</h1>
            <p class="text-gray-600 mt-2">Join CommunityPulse today</p>
        </div>

        <!-- Flash Messages -->
        <% if (typeof messages !== 'undefined' && messages.error) { %>
            <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg mb-6" role="alert">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-red-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span class="text-red-800 font-medium"><%= messages.error %></span>
                </div>
            </div>
        <% } %>
        <% if (typeof messages !== 'undefined' && messages.success) { %>
            <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded-r-lg mb-6" role="alert">
                <div class="flex items-center">
                    <svg class="w-5 h-5 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span class="text-green-800 font-medium"><%= messages.success %></span>
                </div>
            </div>
        <% } %>

        <!-- Registration Form -->
        <form hx-post="/register" 
              hx-target="body" 
              hx-swap="outerHTML"
              hx-indicator="#submit-btn"
              id="register-form"
              @submit.prevent="validateForm()">

            <!-- Username Field -->
            <div class="mb-4">
                <label for="username" class="block text-sm font-medium text-gray-700 mb-2">
                    Username <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                    </div>
                    <input type="text" 
                           id="username" 
                           name="username" 
                           x-model="username"
                           @input="checkUsername()"
                           class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                           placeholder="Choose a username"
                           required
                           minlength="3"
                           maxlength="50"
                           pattern="[a-zA-Z0-9_]+"
                           :class="{ 'border-red-500': errors.username, 'border-green-500': usernameValid && username.length > 0 }">
                </div>
                <p x-show="usernameChecking" class="text-xs text-gray-500 mt-1">Checking availability...</p>
                <p x-show="usernameTaken" class="text-xs text-red-500 mt-1">Username is already taken</p>
                <p x-show="usernameValid && username.length > 0" class="text-xs text-green-500 mt-1">Username is available</p>
                <p x-show="errors.username" class="text-xs text-red-500 mt-1" x-text="errors.username"></p>
            </div>

            <!-- Email Field (Optional) -->
            <div class="mb-4">
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">
                    Email <span class="text-gray-400">(optional)</span>
                </label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>
                    </div>
                    <input type="email" 
                           id="email" 
                           name="email" 
                           x-model="email"
                           class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                           placeholder="your@email.com"
                           :class="{ 'border-red-500': errors.email }">
                </div>
                <p x-show="errors.email" class="text-xs text-red-500 mt-1" x-text="errors.email"></p>
            </div>

            <!-- Password Field -->
            <div class="mb-4">
                <label for="password" class="block text-sm font-medium text-gray-700 mb-2">
                    Password <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                        </svg>
                    </div>
                    <input type="password" 
                           id="password" 
                           name="password" 
                           x-model="password"
                           @input="checkPasswordStrength()"
                           class="w-full pl-10 pr-12 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                           placeholder="Create a strong password"
                           required
                           minlength="8"
                           :class="{ 'border-red-500': errors.password, 'border-green-500': passwordStrength === 'strong' }">
                    
                    <!-- Password Visibility Toggle -->
                    <button type="button" 
                            @click="showPassword = !showPassword"
                            class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 hover:text-gray-600">
                        <svg x-show="!showPassword" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                        </svg>
                        <svg x-show="showPassword" class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path>
                        </svg>
                    </button>
                </div>
                
                <!-- Password Strength Indicator -->
                <div class="mt-2">
                    <div class="flex space-x-1">
                        <div class="h-1 flex-1 rounded" :class="passwordStrengthBar(0)"></div>
                        <div class="h-1 flex-1 rounded" :class="passwordStrengthBar(1)"></div>
                        <div class="h-1 flex-1 rounded" :class="passwordStrengthBar(2)"></div>
                        <div class="h-1 flex-1 rounded" :class="passwordStrengthBar(3)"></div>
                    </div>
                    <p class="text-xs mt-1" 
                       :class="{ 
                           'text-red-500': passwordStrength === 'weak', 
                           'text-yellow-500': passwordStrength === 'medium', 
                           'text-green-500': passwordStrength === 'strong' 
                       }" 
                       x-text="passwordStrengthText()">
                    </p>
                </div>
                <p x-show="errors.password" class="text-xs text-red-500 mt-1" x-text="errors.password"></p>
            </div>

            <!-- Confirm Password Field -->
            <div class="mb-6">
                <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-2">
                    Confirm Password <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <input type="password" 
                           id="confirmPassword" 
                           name="confirmPassword" 
                           x-model="confirmPassword"
                           @input="validatePasswordMatch()"
                           class="w-full pl-10 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                           placeholder="Confirm your password"
                           required
                           :class="{ 'border-red-500': !passwordMatch && confirmPassword.length > 0, 'border-green-500': passwordMatch && confirmPassword.length > 0 }">
                </div>
                <p x-show="!passwordMatch && confirmPassword.length > 0" class="text-xs text-red-500 mt-1">Passwords do not match</p>
                <p x-show="passwordMatch && confirmPassword.length > 0" class="text-xs text-green-500 mt-1">Passwords match</p>
            </div>

            <!-- Terms & Conditions -->
            <div class="mb-6">
                <label class="flex items-start">
                    <input type="checkbox" 
                           name="terms" 
                           required
                           class="w-4 h-4 text-blue-600 rounded focus:ring-blue-500 mt-1"
                           x-model="acceptedTerms">
                    <span class="ml-2 text-sm text-gray-600">
                        I agree to the 
                        <a href="/terms" target="_blank" class="text-blue-600 hover:underline">Terms of Service</a> 
                        and 
                        <a href="/privacy" target="_blank" class="text-blue-600 hover:underline">Privacy Policy</a>
                        <span class="text-red-500">*</span>
                    </span>
                </label>
                <p x-show="!acceptedTerms && submitted" class="text-xs text-red-500 mt-1">You must accept the terms to continue</p>
            </div>

            <!-- Submit Button -->
            <button type="submit" 
                    id="submit-btn"
                    class="w-full bg-blue-600 text-white font-bold py-3 px-4 rounded-lg hover:bg-blue-700 transition disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center space-x-2"
                    :disabled="!isFormValid()">
                <span x-show="!htmxIsRequesting()">Create Account</span>
                <span x-show="htmxIsRequesting()" class="flex items-center space-x-2">
                    <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span>Creating...</span>
                </span>
            </button>

        </form>

        <!-- Login Link -->
        <p class="text-center mt-6 text-gray-600">
            Already have an account? 
            <a href="/login" class="text-blue-600 hover:underline font-medium">Sign in here</a>
        </p>

        <!-- Security Notice -->
        <div class="mt-8 pt-6 border-t border-gray-200">
            <div class="flex items-center justify-center space-x-2 text-xs text-gray-500">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
                <span>Your password is encrypted and stored securely</span>
            </div>
        </div>

    </div>

</div>

<script>
function registerForm() {
    return {
        username: '',
        email: '',
        password: '',
        confirmPassword: '',
        acceptedTerms: false,
        submitted: false,
        showPassword: false,
        usernameValid: false,
        usernameTaken: false,
        usernameChecking: false,
        passwordStrength: 'weak',
        passwordMatch: false,
        errors: {},

        init() {
            setTimeout(() => {
                document.querySelectorAll('[role="alert"]').forEach(el => {
                    el.style.transition = 'opacity 0.5s';
                    el.style.opacity = '0';
                    setTimeout(() => el.remove(), 500);
                });
            }, 5000);
        },

        htmxIsRequesting() {
            const btn = document.getElementById('submit-btn');
            return btn && btn.classList.contains('htmx-request');
        },

        async checkUsername() {
            if (this.username.length < 3) {
                this.usernameValid = false;
                this.usernameTaken = false;
                return;
            }

            this.usernameChecking = true;
            try {
                const response = await fetch('/api/check-username?username=' + encodeURIComponent(this.username));
                const data = await response.json();
                this.usernameTaken = data.taken;
                this.usernameValid = !data.taken;
            } catch (error) {
                console.error('Username check failed:', error);
            } finally {
                this.usernameChecking = false;
            }
        },

        checkPasswordStrength() {
            const password = this.password;
                    let score = 0;

                    // Only basic checks
                    if (password.length >= 4) score++;
                    if (/[a-z]/.test(password)) score++;
                    if (/[0-9]/.test(password)) score++;

                    // Easier grading
                    if (score <= 1) {
                        this.passwordStrength = 'weak';
                    } else if (score === 2) {
                        this.passwordStrength = 'medium';
                    } else {
                        this.passwordStrength = 'strong';
                    }
        },

        passwordStrengthBar(index) {
            const strengths = {
                weak: ['bg-red-500', '', '', ''],
                medium: ['bg-yellow-500', 'bg-yellow-500', '', ''],
                strong: ['bg-green-500', 'bg-green-500', 'bg-green-500', 'bg-green-500']
            };
            const bars = strengths[this.passwordStrength];
            return index < bars.length && bars[index] ? bars[index] : 'bg-gray-200';
        },

        passwordStrengthText() {
            const texts = {
                weak: 'Weak - Use at least 8 characters',
                medium: 'Medium - Add numbers or symbols',
                strong: 'Strong - Great password!'
            };
            return this.password ? texts[this.passwordStrength] : '';
        },

        validatePasswordMatch() {
            this.passwordMatch = this.password === this.confirmPassword && this.confirmPassword.length > 0;
        },

        validateForm() {
            this.submitted = true;
            this.errors = {};

            if (this.username.length < 3) {
                this.errors.username = 'Username must be at least 3 characters';
            }

            if (this.email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.email)) {
                this.errors.email = 'Please enter a valid email address';
            }

            if (this.password.length < 6) {
                this.errors.password = 'Password must be at least 8 characters';
            }

            if (!this.passwordMatch) {
                this.errors.password = 'Passwords do not match';
            }

            if (Object.keys(this.errors).length === 0 && this.isFormValid()) {
                this.$el.querySelector('form').setAttribute('hx-disabled-el', '#submit-btn');
            }
        },

        isFormValid() {
            return this.username.length >= 3 && 
                   this.usernameValid && 
                   this.passwordStrength !== 'weak' && 
                   this.passwordMatch && 
                   this.acceptedTerms &&
                   !this.htmxIsRequesting();
        }
    }
}
</script>